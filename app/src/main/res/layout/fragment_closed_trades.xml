<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".ClosedTradesFragment">

    <!-- רשימת הטריידים הסגורים -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/closedTradesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="88dp"
        android:clipToPadding="false"
        android:scrollbars="vertical" />

    <!-- כפתור צף לניתוח AI -->
    <!-- ממוקם בפינה הימנית התחתונה -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnAnalyzeTrades"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:text="ניתוח AI"
        android:textColor="@android:color/white"
        android:backgroundTint="#6200EE"
        app:icon="@android:drawable/ic_menu_search"
        app:iconTint="@android:color/white"
        app:elevation="6dp"
        android:layoutDirection="rtl"
        android:textDirection="rtl"/>

    <!-- אינדיקטור טעינה (מופיע רק בזמן חישוב) -->
    <ProgressBar
        android:id="@+id/aiProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="#6200EE"/>

</FrameLayout>
