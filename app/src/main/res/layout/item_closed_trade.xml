<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardElevation="4dp"
    app:strokeWidth="2dp"
    app:strokeColor="#2196F3"
    app:cardCornerRadius="15dp"
    android:backgroundTint="#FFFFFF">

    <!-- שימוש ב-RelativeLayout כדי למקם את כפתור העריכה בפינה -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- כפתור העריכה בפינה הימנית העליונה -->
        <ImageButton
            android:id="@+id/btnEditTrade"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Edit Trade"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="#757575" />

        <!-- המבנה המקורי שלך -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layoutDirection="ltr"
            android:orientation="vertical"
            android:padding="18dp"
            android:textDirection="ltr">

            <!-- Symbol -->
            <TextView
                android:id="@+id/tradeSymbolText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:layoutDirection="ltr"
                android:text="SYMBOL"
                android:textColor="#1A237E"
                android:textDirection="ltr"
                android:textSize="21sp"
                android:textStyle="bold" />

            <!-- P&L and percent change box -->
            <LinearLayout
                android:id="@+id/resultBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:layoutDirection="ltr"
                android:orientation="horizontal"
                android:padding="12dp"
                android:textDirection="ltr">

                <TextView
                    android:id="@+id/pnlView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:layoutDirection="ltr"
                    android:text="P&amp;L: $0.00"
                    android:textColor="#D32F2F"
                    android:textDirection="ltr"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tradeChangePercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layoutDirection="ltr"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:text="0.00%"
                    android:textColor="#222"
                    android:textDirection="ltr"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Trade details -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical"
                android:layoutDirection="ltr"
                android:orientation="horizontal"
                android:textDirection="ltr">

                <TextView
                    android:id="@+id/tradeBuyPrice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layoutDirection="ltr"
                    android:text="Entry: \n0.00"
                    android:textColor="#222"
                    android:textDirection="ltr"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tradeSellingPrice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layoutDirection="ltr"
                    android:text="Exit\n0.00"
                    android:textColor="#222"
                    android:textDirection="ltr"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tradeCurrentPrice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layoutDirection="ltr"
                    android:text="Current\n0.00"
                    android:textColor="#222"
                    android:textDirection="ltr"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
